# ── Flow Chile ────────────────────────────────────────────────────
# Obtén tus credenciales en https://www.getflow.cl
FLOW_API_KEY=TU_API_KEY_DE_FLOW
FLOW_SECRET_KEY=TU_SECRET_KEY_DE_FLOW
# sandbox: https://sandbox.flow.cl/api | producción: https://www.flow.cl/api
FLOW_BASE_URL=https://www.flow.cl/api

# ── Supabase ───────────────────────────────────────────────────────
# Settings → API en https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Supabase (frontend — prefijo VITE_ obligatorio para Vite) ─────
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── URLs públicas ──────────────────────────────────────────────────
PUBLIC_URL=https://mitienditadigitalve.com
VITE_API_URL=https://mitienditadigitalve.com

# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_PIN=<pin-secreto-para-panel-admin>

# ── Resend (emails transaccionales) ───────────────────────────────
# Obtén tu clave en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Una vez verificado el dominio en resend.com/domains:
RESEND_FROM=Mi Tiendita Digital Ve <noreply@mitienditadigitalve.com>
